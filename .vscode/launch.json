{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python：调试当前文件",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "云端 API：FastAPI 8001",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "cloud.cloud_service:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--reload"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "可视化：Streamlit 8501",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "dashboard/app.py",
        "--server.port",
        "8501",
        "--server.address",
        "127.0.0.1"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "系统：云端 API + 仪表盘",
      "configurations": [
        "云端 API：FastAPI 8001",
        "可视化：Streamlit 8501"
      ],
      "stopAll": true
    }
  ]
}
