# 运行模式：mock（模拟）或 real（真实API）
GCM_MODE=real

# Qwen3.5-35B API地址（Responses API风格）
GCM_35B_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1

# Qwen3-14B API地址（Chat Completions API风格）
GCM_14B_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 主模型：Qwen3.5-35B
GCM_MODEL=qwen3.5-35b-a3b

# 备用模型：Qwen3-14B（主模型失败时自动降级）
GCM_BACKUP_MODEL=qwen3-14b

# API Key（替换为你的阿里云百炼API密钥，.env文件不会上传到GitHub）
GCM_API_KEY=sk-xxx

# 请求超时时间（秒）
GCM_TIMEOUT=60